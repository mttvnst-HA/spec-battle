{
  "name": "spec-battle-rpg",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "sim": "node scripts/simulate.js",
    "sim:update-baseline": "node scripts/simulate.js --update-baseline",
    "tune": "node scripts/tune.js",
    "tune:dry-run": "node scripts/tune.js --dry-run",
    "tune:llm": "node scripts/tune.js --llm",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:preview": "vite build && electron ."
  },
  "build": {
    "appId": "com.specbattle.rpg",
    "productName": "Spec Battle",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Spec Battle"
    },
    "publish": [{
      "provider": "github",
      "owner": "mttvnst",
      "repo": "spec-battle"
    }]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.3"
  }
}
